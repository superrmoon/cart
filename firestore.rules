rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // User's own lists only
    match /users/{userId}/lists/{listId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
